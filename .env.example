# Chain
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# Superfluid (same address on all EVM chains)
NEXT_PUBLIC_CFA_FORWARDER=0xcfA132E353cB4E398080B9700609bb008eceB125

# Tokens on Base Sepolia
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_USDCX_ADDRESS=<find on app.superfluid.finance — switch to Base Sepolia>

# Deployed contracts (fill after Dev A deploys)
NEXT_PUBLIC_REGISTRY_ADDRESS=<fill after deploy>
NEXT_PUBLIC_VAULT_FACTORY_ADDRESS=<fill after deploy>

# Swarm (server-side only — never NEXT_PUBLIC_)
SWARM_BEE_URL=http://localhost:1633
SWARM_POSTAGE_BATCH_ID=<get from Swarm booth gift code at ETHPrague>

# Swarm public gateway (client-side)
NEXT_PUBLIC_SWARM_GATEWAY=https://api.gateway.ethswarm.org

# WalletConnect Cloud
NEXT_PUBLIC_WC_PROJECT_ID=<from cloud.walletconnect.com>

# Apify (if building reader agent)
APIFY_TOKEN=<from apify.com dashboard>

# Deployer wallet (contracts only — never commit the real .env)
DEPLOYER_KEY=<private key of your deployer wallet>
BASESCAN_API_KEY=<from sepolia.basescan.org — free account>
