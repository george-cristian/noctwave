# Chain
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# Superfluid (same address on all EVM chains)
NEXT_PUBLIC_CFA_FORWARDER=0xcfA132E353cB4E398080B9700609bb008eceB125

# Tokens on Base Sepolia
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_USDCX_ADDRESS=0x1650581f573ead727b92073b5ef8b4f5b94d1648  # fUSDCx on Base Sepolia

# ENS — Ethereum Sepolia (identity layer)
ENS_REGISTRY=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
ENS_PUBLIC_RESOLVER=<find on app.ens.domains after registering name on Sepolia>
ENS_ROOT_NODE=<compute with: cast namehash <your-ens-name>>
NEXT_PUBLIC_ENS_REGISTRAR_ADDRESS=<fill after DeployENS.s.sol>
NEXT_PUBLIC_ENS_CHAIN_ID=11155111
NEXT_PUBLIC_ENS_RPC_URL=https://rpc.sepolia.org

# Base Sepolia contracts (payment layer)
NEXT_PUBLIC_VAULT_FACTORY_ADDRESS=<fill after DeployBase.s.sol>

# Swarm — gateway only, no Bee node needed, NULL_STAMP accepted by bzz.limo
NEXT_PUBLIC_SWARM_GATEWAY=https://bzz.limo

# WalletConnect Cloud
NEXT_PUBLIC_WC_PROJECT_ID=<from cloud.walletconnect.com>

# Apify (if building reader agent)
APIFY_TOKEN=<from apify.com dashboard>

# Deployer wallet (contracts only — never commit the real .env)
DEPLOYER_KEY=<private key of your deployer wallet>
BASESCAN_API_KEY=<from sepolia.basescan.org — free account>
ETHERSCAN_API_KEY=<from etherscan.io — free account, needed for ENS contract verification>
